    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "file-saver": "^2.0.5",
    "firebase": "^10.12.2",
    "history": "4.10.1",
    "lodash": "^4.17.11",
    "react": "18.3.1",
    "react-beautiful-dnd": "^13.1.1",
    "react-dom": "18.3.1",
    "react-firebase-hooks": "^5.1.1",
    "react-ga": "^3.3.1",
    "react-helmet": "^6.1.0",
    "react-router": "5.3.4",
    "react-router-dom": "^5.3.4",
    "semantic-ui-css": "^2.5.0",
    "semantic-ui-react": "^2.1.5",
    "typescript": "^5.4.5",
    "vite": "^5.4.2",
    "vite-plugin-svgr": "^4.2.0",
    "vite-tsconfig-paths": "^5.0.1"
  },
  "devDependencies": {
    "@types/history": "^4.7.11",
    "@types/react-router": "^5.1.20",
    "@vitest/coverage-v8": "^2.0.5",
    "cypress": "13.11.0",
    "cypress-real-events": "^1.12.0",
    "firebase-tools": "^15.18.0",
    "jsdom": "^25.0.0",
    "vitest": "^2.0.5"
  },
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "serve": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage --watch=false",
    "emulators": "node ./scripts/firebase-emulators.mjs start",
    "deploy:database-rules": "firebase deploy --only database --project muncoordinated",
    "deploy:storage-rules": "firebase deploy --only storage --project muncoordinated",
    "deploy:rules": "firebase deploy --only database,storage --project muncoordinated",
    "cypress:run": "cypress run",
    "cypress:open": "cypress open",
    "cypress:run:emulators": "node ./scripts/run-cypress-with-emulators.mjs run",
    "cypress:open:emulators": "node ./scripts/run-cypress-with-emulators.mjs open",
    "test:e2e": "node ./scripts/firebase-emulators.mjs test"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ]
